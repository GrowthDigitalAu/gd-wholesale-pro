{% if shop.metafields.gd_price_updator.subscription_active == 'true' %}
  {% assign selected_product = block.settings.product %}
  {% assign has_b2b_tag = false %}
  {% for tag in customer.tags %}
    {% assign tag_downcase = tag | downcase %}
    {% if tag_downcase == 'b2b_approved' %}
      {% assign has_b2b_tag = true %}
    {% endif %}
  {% endfor %}

  <b2b-prod-price id="b2b-price-container-{{ block.id }}" class="js-gd-ext-b2b-price-block">
    <div class="js-b2b-price-wrapper">
      {% assign current_variant = selected_product.selected_or_first_available_variant %}
      {% assign b2b_price = current_variant.metafields['$app'].gd_b2b_price.value | times: 100 %}
      {% assign b2b_min_qty = current_variant.metafields['$app'].gd_b2b_min_qty.value | plus: 0 %}

      {% if has_b2b_tag and b2b_price > 0 %}
        <div class="b2b-price-wrapper b2b-customer-price">
          <div class="b2b-price-group">
            <span class="b2b-price-current">
              {{ b2b_price | money_with_currency }}
            </span>
            <span class="b2b-price-original" style="text-decoration: line-through;">
              {{- current_variant.price | money_with_currency -}}
            </span>
          </div>
          {% if b2b_min_qty and b2b_min_qty > 1 %}
            <div class="b2b-min-qty-text b2b-min-qty-wrapper">
              <span class="b2b-min-qty-inner-text">
                {{- block.settings.min_qty_text | replace: '[b2b_min_qty]', b2b_min_qty -}}
              </span>
            </div>
          {% endif %}
        </div>
      {% elsif current_variant.compare_at_price > current_variant.price %}
        <div class="b2b-price-wrapper b2b-regular-sale">
          <span class="b2b-price-current">{{ current_variant.price | money_with_currency }}</span>
          <span class="b2b-price-compare" style="text-decoration: line-through;">
            {{- current_variant.compare_at_price | money_with_currency -}}
          </span>
        </div>
      {% else %}
        <div class="b2b-price-wrapper b2b-regular-price">
          <span class="b2b-price-current">{{ current_variant.price | money_with_currency }}</span>
        </div>
      {% endif %}
    </div>

    <script type="application/json">
      {
        "isB2B": {{ has_b2b_tag | json }},
        "moneyFormat": {{ shop.money_with_currency_format | json }},
        "variantsData": {
          {% for variant in selected_product.variants %}
            "{{ variant.id }}": {
              "price": {{ variant.price }},
              "compare_at_price": {% if variant.compare_at_price %}{{ variant.compare_at_price }}{% else %}null{% endif %},
              "b2b_price": {% if variant.metafields["$app"].gd_b2b_price.value %}{{ variant.metafields["$app"].gd_b2b_price.value | times: 100 }}{% else %}null{% endif %},
              "b2b_min_qty": {% if variant.metafields["$app"].gd_b2b_min_qty.value %}{{ variant.metafields["$app"].gd_b2b_min_qty.value | plus: 0 | json }}{% else %}null{% endif %}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        },
        "blockId": "{{ block.id }}",
        "selectedVariantId": "{{ selected_product.selected_or_first_available_variant.id }}",
        "minQtyText": {{ block.settings.min_qty_text | json }}
      }
    </script>

    <style>
      .b2b-min-qty-text {
        font-size: 0.8em;
        font-weight: normal;
        color: red;
        display: block;
        width: 100%;
      }
    </style>
    <style style="display: none;">
      {{ block.settings.custom_css }}
    </style>
  </b2b-prod-price>
{% endif %}

{% schema %}
{
  "name": "B2B Product Price",
  "class": "gd-b2b-product-price",
  "target": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "product",
      "autofill": true
    },
    {
      "type": "text",
      "id": "min_qty_text",
      "label": "Min Qty Text",
      "default": "A minimum quantity of [b2b_min_qty] is required to qualify for this price.",
      "info": "Use \"[b2b_min_qty]\" to display the minimum quantity."
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "info": "Add custom CSS here."
    }
  ]
}
{% endschema %}
